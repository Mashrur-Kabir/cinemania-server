model WatchedHistory {
    id        String   @id @default(uuid())
    userId    String
    mediaId   String
    watchedAt DateTime @default(now()) // The "Diary" date
    notes     String?  @db.Text // Brief thoughts/mood while watching
    isRewatch Boolean  @default(false)

    lastPosition Int     @default(0) // Progress in seconds
    duration     Int     @default(0) // Total duration in seconds
    isCompleted  Boolean @default(false) // Marks if user finished the movie

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
    media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([mediaId])
}
