model Media {
    id           String    @id @default(uuid())
    title        String
    slug         String    @unique
    description  String
    releaseYear  Int
    director     String
    cast         String[]
    platform     String
    pricing      Pricing   @default(FREE)
    streamingUrl String?
    isDeleted    Boolean   @default(false)
    deletedAt    DateTime?

    //performance counters
    averageRating Float @default(0)
    reviewCount   Int   @default(0)
    viewCount     Int   @default(0)
    likeCount     Int   @default(0)
    watchCount    Int   @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    genres           MediaGenre[]
    reviews          Review[]
    watchlist        Watchlist[]
    watchedHistories WatchedHistory[]

    @@index([title])
    @@index([releaseYear]) // Added: Sorting/filtering by year
    @@index([platform]) // Added: Filtering by streaming platform
    @@index([pricing]) // Added: Filtering Free vs Premium content
}
