<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Verified | Cinemania</title>
    <style>
        body { font-family: 'Inter', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #020617; margin: 0; color: #f8fafc; }
        .loader { text-align: center; background: #0f172a; padding: 40px; border-radius: 24px; border: 1px solid #1e293b; }
        .spinner { border: 4px solid #1e293b; border-top: 4px solid #10b981; /* Green for Success */ border-radius: 50%; width: 44px; height: 44px; animation: spin 1s linear infinite; margin: 0 auto 24px; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        h2 { color: #ffffff; font-size: 18px; font-weight: 600; margin: 0; }
        p { color: #64748b; font-size: 14px; margin-top: 8px; }
    </style>
</head>
<body>
    <div class="loader">
        <div class="spinner"></div>
        <h2>Identity Verified</h2>
        <p>Syncing your cinematic profile...</p>
    </div>

    <script>
        const authData = {
            success: true,
            user: <%- JSON.stringify(user) %>,
            accessToken: "<%= accessToken %>",
            refreshToken: "<%= refreshToken %>",
            sessionToken: "<%= sessionToken %>"
        };

        // Communication logic for Popups vs Redirects
        if (window.opener) {
            window.opener.postMessage(
                { type: "GOOGLE_LOGIN_SUCCESS", payload: authData },
                "<%= frontendUrl %>" 
            );
            
            setTimeout(() => {
                window.close();
            }, 500); // Brief pause to ensure message delivery
        } else {
            // Direct redirect fallback
            window.location.href = "<%= frontendUrl %><%= redirectPath %>";
        }
    </script>
</body>
</html>